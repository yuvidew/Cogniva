generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Agent {
  id                     String             @id @default(cuid())
  name                   String             @db.VarChar(100)
  description            String             @db.VarChar(300)
  avatar                 String?
  systemPrompt           String
  model                  AgentModelProvider
  temperature            Float
  memoryEnabled          Boolean            @default(false)
  webSearchEnabled       Boolean            @default(false)
  fileUploadEnabled      Boolean            @default(false)
  strictMode             Boolean            @default(false)
  isActive               Boolean            @default(true)
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  ownerId                String
  imageProcessingEnabled Boolean            @default(false)
  videoProcessingEnabled Boolean            @default(false)
  imageGenerationEnabled Boolean            @default(false)
  owner                  User               @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  chats                  Chat[]
  fileUploads            FileUpload[]
  generatedImages        GeneratedImage[]
  processedImages        ProcessedImage[]
  processedVideos        ProcessedVideo[]

  @@index([isActive])
  @@index([ownerId])
  @@map("agent")
}

model User {
  id              String           @id
  name            String
  email           String           @unique
  emailVerified   Boolean          @default(false)
  image           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  accounts        Account[]
  agents          Agent[]
  chats           Chat[]
  chatMessages    ChatMessage[]
  fileUploads     FileUpload[]
  generatedImages GeneratedImage[]
  processedImages ProcessedImage[]
  processedVideos ProcessedVideo[]
  sessions        Session[]

  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model Chat {
  id        String        @id @default(cuid())
  title     String        @db.VarChar(200)
  status    ChatStatus    @default(active)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  userId    String
  agentId   String
  agent     Agent         @relation(fields: [agentId], references: [id], onDelete: Cascade)
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  ChatMessage[]

  @@index([userId])
  @@index([agentId])
  @@index([status])
  @@index([createdAt])
  @@map("chat")
}

model ChatMessage {
  id          String       @id @default(cuid())
  content     String
  role        MessageRole
  createdAt   DateTime     @default(now())
  chatId      String
  senderId    String?
  chat        Chat         @relation(fields: [chatId], references: [id], onDelete: Cascade)
  sender      User?        @relation(fields: [senderId], references: [id])
  attachments FileUpload[]

  @@index([chatId])
  @@index([createdAt])
  @@map("chat_message")
}

model FileUpload {
  id         String           @id @default(cuid())
  fileName   String           @db.VarChar(255)
  fileUrl    String
  fileSize   Int
  mimeType   String           @db.VarChar(100)
  status     FileUploadStatus @default(completed)
  createdAt  DateTime         @default(now())
  uploaderId String
  messageId  String?
  agentId    String?
  agent      Agent?           @relation(fields: [agentId], references: [id], onDelete: Cascade)
  message    ChatMessage?     @relation(fields: [messageId], references: [id])
  uploader   User             @relation(fields: [uploaderId], references: [id], onDelete: Cascade)

  @@index([uploaderId])
  @@index([agentId])
  @@index([messageId])
  @@map("file_upload")
}

model Workflow {
  id   String @id @default(cuid())
  name String @db.VarChar(100)
}

model ProcessedImage {
  id             String           @id @default(cuid())
  originalUrl    String
  processedUrl   String?
  fileName       String           @db.VarChar(255)
  mimeType       String           @db.VarChar(100)
  fileSize       Int
  width          Int?
  height         Int?
  processingType String           @db.VarChar(50)
  metadata       Json?
  status         ProcessingStatus @default(pending)
  errorMessage   String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  userId         String
  agentId        String?
  agent          Agent?           @relation(fields: [agentId], references: [id], onDelete: Cascade)
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([agentId])
  @@index([status])
  @@index([createdAt])
  @@map("processed_image")
}

model ProcessedVideo {
  id             String           @id @default(cuid())
  originalUrl    String
  processedUrl   String?
  thumbnailUrl   String?
  fileName       String           @db.VarChar(255)
  mimeType       String           @db.VarChar(100)
  fileSize       Int
  duration       Int?
  width          Int?
  height         Int?
  processingType String           @db.VarChar(50)
  metadata       Json?
  status         ProcessingStatus @default(pending)
  errorMessage   String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  userId         String
  agentId        String?
  agent          Agent?           @relation(fields: [agentId], references: [id], onDelete: Cascade)
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([agentId])
  @@index([status])
  @@index([createdAt])
  @@map("processed_video")
}

model GeneratedImage {
  id             String                @id @default(cuid())
  prompt         String
  negativePrompt String?
  imageUrl       String?
  width          Int                   @default(1024)
  height         Int                   @default(1024)
  model          String                @db.VarChar(100)
  style          String?               @db.VarChar(50)
  quality        String?               @db.VarChar(20)
  metadata       Json?
  status         ImageGenerationStatus @default(pending)
  errorMessage   String?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  userId         String
  agentId        String?
  agent          Agent?                @relation(fields: [agentId], references: [id], onDelete: Cascade)
  user           User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([agentId])
  @@index([status])
  @@index([createdAt])
  @@map("generated_image")
}

enum AgentModelProvider {
  openai
  anthropic
  google

  @@map("agent_model_provider")
}

enum ChatStatus {
  active
  resolved
  archived

  @@map("chat_status")
}

enum MessageRole {
  user
  assistant
  system

  @@map("message_role")
}

enum FileUploadStatus {
  uploading
  completed
  failed

  @@map("file_upload_status")
}

enum ProcessingStatus {
  pending
  processing
  completed
  failed

  @@map("processing_status")
}

enum ImageGenerationStatus {
  pending
  generating
  completed
  failed

  @@map("image_generation_status")
}
